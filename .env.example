# ─── DenAI Configuration ─────────────────────────────────────────────────
# Copy this file to .env and customize as needed.
# All values below are the defaults — uncomment to override.

# ─── Server ──────────────────────────────────────────────────────────────
# DENAI_HOST=127.0.0.1
# DENAI_PORT=4078
# DENAI_SHARE=false

# ─── Ollama ──────────────────────────────────────────────────────────────
# DENAI_OLLAMA_URL=http://localhost:11434
# DENAI_MODEL=llama3.1:8b

# ─── LLM Tuning ─────────────────────────────────────────────────────────
# DENAI_MAX_TOOL_ROUNDS=25       # Max tool call rounds per message (1-100)
# DENAI_MAX_CONTEXT=65536        # Max context window in tokens (2048-131072)

# ─── Security ────────────────────────────────────────────────────────────
# DENAI_RATE_LIMIT=30            # Requests per minute per IP
